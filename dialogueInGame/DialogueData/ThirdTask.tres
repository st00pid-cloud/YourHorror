script = ExtResource("1_ruf22")
character_name = "[Uhhh] Refactor Muli Nakshi"
lines = Array[String](["The player reaches the Main Distribution Frame where the \"Gateway\" is located.", "[FLESH] Alright, got the Routing Loop.", "{Show packets are bouncing between the Gateway and the Null Route. The Time to Live Status is expiring and the router is spiking to 100% CPU} ", "[FLESH] Have to find the leaking IP ", "[FLESH] Already traced the loop to the UPS room, looking at the gateway router ... 
", "{Show CAT6 cables are not plugged into the RJ45 ports. They have been threaded} ", "[FLESH] ...", "{The reveal of the engineer inside the data rack} "])
