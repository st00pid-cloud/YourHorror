[resource]
script = ExtResource("1_oi08n")
character_name = "FLESH"
lines = Array[String](["[BOB] There's an intermittent link status on the Core-01 trunk. Port 48 is flapping every three seconds. Check the SFP+ module. It might be an overheating laser.  ", "You're at the rack, the LED is supposed to be green. (show red inGame) ", "I'll have to pull the SFP module now.  ", "{Sound of metal sliding against metal. A wet suction-like squelch follows}  ", "[Show black tar inGame: Description: The module is coated in a viscious, conductive gel, not thermal paste. The port is constricting around the cable] ", "I have to clean this with alcohol and research. Light levels might drop and the whole subnet goes dark if I don't do that.  ", "... "])
metadata/_custom_type_script = "uid://gu8ukt4kb2yf"
