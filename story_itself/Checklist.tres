[resource]
script = ExtResource("1_dbtm5")
dialogue_lines = Array[String](["[BOB] Hey there [FLESH] ", "[FLESH] Place’s about to fall apart, I don’t think the checklist’s any use.  ", "[BOB] ProjManager probably never told you this but we’re paid extra to survey this area. Though ... yeah I do agree. Whatever they’re hosting here must be something beyond our minds. It’s a miracle how they even got their racks working looking at the poor ventilation and grounding here. ", "[FLESH] ... Are we going to get a bonus then?  ", "[BOB] No clue, probably...  ", "[FLESH] I'm gonna go on then. ", "[BOB] Sure, copy. ", ""])
metadata/_custom_type_script = "uid://ybyxov2ojw03"
