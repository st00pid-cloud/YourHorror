[gd_resource type="Resource" load_steps=2 format=3 uid="uid://gsiy0feigc8b"]

[sub_resource type="GDScript" id="GDScript_qhuta"]
script/source = "var dialogue_lines = [
\"The hum of the cooling fans was low, rhythmic thrumming that felt less like machinery and more like a heartbeat. Someone stepped deeper into Row 42, flashlight cutting through the dry filtered air.\",
\"'Hey, I'm at the source. But the biometric lock wasn't bypassed. It was ... melted\",
\"The flashlight beam wavered\",
\"'Hey [flesh], status.' Communications crackled\",
\"No words, infront a body who had gone dark, 48 hours ago, suspended\",
\"[Superior] 'Do not pull the bridge'\",
\" Pull the bridge [YES | YES]\",
\"[FLESH] '... There's something strange here, no ID at all, can't see anything.' \",
\"[Superior] I told you not to pull the bridge [flesh]\",
\"[FLESH] '...'\",
\"[Superior] 'The packets, they're heavy. I can feel the encryption keys scraping against my spine. It's not leak, it's overflow' \",
\"You wave your flashlight infront of a server rack. Look closer? [YES | YES]\",
\"You look closer \",
\"[FLESH] (Is this guy even breathing?)\",
\"[???] 'I'm I'm I'm buffering buffering'\",
\"[???] 'You should should should should see see the throughput from the inside inside inside'\",
\"A >>hand<< reaches out for you to see the throughput. Will you look at it? [YES | YES]\",
\"You're pulled into an artificial womb for a new kind of architecture. There are networks of transluscent, vein-like tubes carrying some kind of liquid. The cables have stripped themselves, stitched into the mans back.\",
\"You cave into the smell of ozone and copper, this is not a malfunction.\",
\"You black out.\"
]
"

[resource]
script = SubResource("GDScript_qhuta")
